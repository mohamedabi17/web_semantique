data:web_semantique a ex:Document,
        rdf:Statement,
        owl:Thing,
        foaf:Person ;
    rdfs:label "Web Sémantique"@fr ;
    ex:confidence "0.9"^^xsd:float ;
    ex:extractionMethod "hybrid_ner"^^xsd:string ;
    owl:sameAs data:web_semantique ;
    foaf:name "Web Sémantique"@fr .

