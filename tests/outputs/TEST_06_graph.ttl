ex:age a owl:DatatypeProperty ;
    rdfs:label "âge"@fr ;
    rdfs:comment "Âge d'une personne en années"@fr ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf ex:age ;
    owl:equivalentProperty ex:age ;
    owl:sameAs ex:age .

ex:collaboratesWith a owl:ObjectProperty ;
    rdfs:label "collabore avec"@fr ;
    rdfs:comment "Relation de collaboration entre deux personnes"@fr ;
    rdfs:domain owl:Thing,
        foaf:Person ;
    rdfs:range owl:Thing,
        foaf:Person ;
    rdfs:subPropertyOf ex:collaboratesWith ;
    owl:equivalentProperty ex:collaboratesWith ;
    owl:sameAs ex:collaboratesWith .

ex:confidence a owl:DatatypeProperty ;
    rdfs:label "Confidence Score"@en ;
    rdfs:comment "Score de confiance d'une assertion (0.0 à 1.0)"@fr ;
    rdfs:domain rdf:Statement ;
    rdfs:range xsd:float ;
    rdfs:subPropertyOf ex:confidence ;
    owl:equivalentProperty ex:confidence ;
    owl:sameAs ex:confidence .

ex:extractionMethod a owl:DatatypeProperty ;
    rdfs:domain rdf:Statement ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf ex:extractionMethod ;
    owl:equivalentProperty ex:extractionMethod ;
    owl:sameAs ex:extractionMethod .

ex:intitule a owl:DatatypeProperty ;
    rdfs:label "intitulé"@fr ;
    rdfs:comment "Titre ou intitulé d'un document"@fr ;
    rdfs:domain ex:Document,
        owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf ex:intitule ;
    owl:equivalentProperty ex:intitule ;
    owl:sameAs ex:intitule .

ex:locatedIn a owl:ObjectProperty ;
    rdfs:label "situé à"@fr ;
    rdfs:comment "Relation de localisation géographique"@fr ;
    rdfs:domain rdfs:Resource ;
    rdfs:range schema1:Place,
        owl:Thing ;
    rdfs:subPropertyOf ex:locatedIn ;
    owl:equivalentProperty ex:locatedIn ;
    owl:sameAs ex:locatedIn .

ex:manages a owl:ObjectProperty ;
    rdfs:label "gère"@fr ;
    rdfs:comment "Relation de gestion/direction d'une organisation"@fr ;
    rdfs:domain owl:Thing,
        foaf:Person ;
    rdfs:range schema1:Organization,
        owl:Thing ;
    rdfs:subPropertyOf ex:manages ;
    owl:equivalentProperty ex:manages ;
    owl:sameAs ex:manages .

ex:relatedTo a owl:ObjectProperty ;
    rdfs:label "en relation avec"@fr ;
    rdfs:comment "Relation générique entre deux ressources"@fr ;
    rdfs:domain rdfs:Resource ;
    rdfs:range rdfs:Resource ;
    rdfs:subPropertyOf ex:relatedTo ;
    owl:equivalentProperty ex:relatedTo ;
    owl:sameAs ex:relatedTo .

ex:studiesAt a owl:ObjectProperty ;
    rdfs:label "étudie à"@fr ;
    rdfs:comment "Relation entre un étudiant et son établissement"@fr ;
    rdfs:domain owl:Thing,
        foaf:Person ;
    rdfs:range schema1:Organization,
        owl:Thing ;
    rdfs:subPropertyOf ex:studiesAt ;
    owl:equivalentProperty ex:studiesAt ;
    owl:sameAs ex:studiesAt .

ex:teaches a owl:ObjectProperty ;
    rdfs:label "enseigne à"@fr ;
    rdfs:comment "Relation entre une personne et le lieu où elle enseigne"@fr ;
    rdfs:domain owl:Thing,
        foaf:Person ;
    rdfs:range schema1:Place,
        owl:Thing ;
    rdfs:subPropertyOf ex:teaches ;
    owl:equivalentProperty ex:teaches ;
    owl:sameAs ex:teaches .

ex:teachesSubject a owl:ObjectProperty ;
    rdfs:label "enseigne la matière"@fr ;
    rdfs:comment "Relation entre un enseignant et la matière qu'il enseigne"@fr ;
    rdfs:domain owl:Thing,
