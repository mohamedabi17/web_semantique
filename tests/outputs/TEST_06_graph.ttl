    rdfs:domain owl:Thing,
        foaf:Person ;
    rdfs:range schema1:Organization,
        owl:Thing ;
    rdfs:subPropertyOf ex:worksAt ;
    owl:equivalentProperty ex:worksAt ;
    owl:sameAs ex:worksAt .

